\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{preamble}[2026/03/19 Astrolabe paper preamble]

% ---------- encoding & fonts ----------
\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage{lmodern}

% ---------- mathematics ----------
\RequirePackage{amsmath,amssymb,amsthm}

% ---------- layout ----------
\RequirePackage{geometry}
\geometry{margin=1in}
\RequirePackage{indentfirst}
\emergencystretch=2em

% ---------- hyperlinks ----------
\RequirePackage{hyperref}
\hypersetup{
  colorlinks=true,
  linkcolor=blue!70!black,
  citecolor=green!50!black,
  urlcolor=blue!70!black
}

% ---------- colors ----------
\RequirePackage{xcolor}

% ---------- tables ----------
\RequirePackage{booktabs}

% ---------- graphics & floats ----------
\RequirePackage{graphicx}
\RequirePackage{float}
\RequirePackage{subcaption}

% ---------- diagrams ----------
\RequirePackage{tikz}
\usetikzlibrary{arrows.meta,positioning}
\RequirePackage{tikz-cd}

% ---------- finding boxes ----------
\newsavebox{\findingbox}
\newenvironment{finding}[1][]{%
  \begin{lrbox}{\findingbox}%
  \begin{minipage}{\dimexpr\linewidth-12pt}%
  \ifx&#1&\else{\bfseries #1}\par\smallskip\fi
}{%
  \end{minipage}%
  \end{lrbox}%
  \par\medskip\noindent
  \fcolorbox{blue!75!black}{blue!5!white}{%
    \usebox{\findingbox}%
  }%
  \par\medskip
}

% ---------- author comments ----------
\newcommand{\xinze}[1]{\textcolor{blue}{(\textbf{Xinze}: #1)}}

% ---------- theorem environments ----------
\newtheorem{definition}{Definition}[section]
\newtheorem{theorem}[definition]{Theorem}
\newtheorem{proposition}[definition]{Proposition}
\newtheorem{corollary}[definition]{Corollary}
\newtheorem{lemma}[definition]{Lemma}
\newtheorem{example}[definition]{Example}
\newtheorem{remark}[definition]{Remark}
