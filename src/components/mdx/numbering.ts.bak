// ============================================================================
// BACKUP of numbering.ts @ commit 70d00aaa (2026-07-02) — 重写前的原版
//
// 逻辑概括:
// - 输出 Numbering = Map<hash, {chapter, num}>,由 buildProjectNumbering 构建。
// - 路线 1(优先):遍历 entries,parse 每张卡的 record,若有 from.at 字符串
//   (且 sort !== 'proof')就直接用它当编号 num,chapter = parseInt(at)。
//   —— 即 Morgan–Tian 两级 `章.序号`,来自卡片自身存的源书标号。
// - 路线 2(fallback,仅对路线 1 没覆盖的 hash):把 docs 按文件名排序,
//   每个 doc 的 chapter 取自 `# Chapter N` 标题(否则文件名前缀数字);
//   逐行扫描,`## §N` 行更新当前 section 号,每个 section 维护独立的 item
//   计数器;对每个 \entryblock{hash},首次出现才编号(proof 跳过),
//   得到 `chapter.section.item` 三级号 —— 为 flat 的 do Carmo 项目保留。
// - 已知问题:对无 `## §N` 小节的书,路线 2 会产出 `X.0.Y`(section 恒 0)。
// ============================================================================

/**
 * Entry numbering.
 *
 * Two sources, in priority order:
 *
 * 1. The card's own `from.at` — the source label stored on the card (Morgan–Tian
 *    numbers `chapter.item`, e.g. `0.2`, `7.27`). This is authentic and stable:
 *    it does not depend on which docs currently exist, and it survives the move
 *    to a card-based (doc-less) layout.
 * 2. Doc-derived `§section.item` fallback — for projects whose cards carry no
 *    `from` pointer (the flat do-Carmo project, whose chapters use `## §N`
 *    numbered sections). The item counter resets at each `## §N` heading and runs
 *    across all sorts; first `\entryblock` occurrence of a hash wins; proofs are
 *    not numbered.
 *
 * The chapter is the number's leading segment. A book that numbers `chapter.item`
 * (no `## §N` sections) must use route 1 — otherwise its section is always 0
 * (`1.0.item`), which is wrong.
 */
export interface EntryNumber {
    chapter: number
    num: string        // e.g. "0.2" (from.at) or "7.2.8" (doc-derived)
}

export type Numbering = Map<string, EntryNumber>

const CHAPTER_RE = /^#\s+Chapter\s+(\d+)\b/m
const SECTION_RE = /^##\s+§?\s*(\d+)\b/
const ENTRYBLOCK_RE = /\\entryblock\{([^}]+)\}/g

/** Chapter number for a doc, from its `# Chapter N` title (else filename prefix). */
export function chapterOf(content: string, filename: string): number {
    const m = content.match(CHAPTER_RE)
    if (m) return parseInt(m[1], 10)
    const fm = filename.match(/^(\d+)-/)
    return fm ? parseInt(fm[1], 10) : 0
}

function isProof(hash: string, entries?: Record<string, { record: string }>): boolean {
    if (!entries?.[hash]) return false
    try { return JSON.parse(entries[hash].record).sort === 'proof' } catch { return false }
}

/** Number every first-seen `\entryblock` in one chapter doc → hash → "§.item". */
function numberDoc(mdx: string, entries?: Record<string, { record: string }>): Map<string, string> {
    const map = new Map<string, string>()
    const counters = new Map<number, number>()   // §section → running item count
    let section = 0
    for (const line of mdx.split('\n')) {
        const sm = line.match(SECTION_RE)
        if (sm) { section = parseInt(sm[1], 10); continue }
        ENTRYBLOCK_RE.lastIndex = 0
        let m: RegExpExecArray | null
        while ((m = ENTRYBLOCK_RE.exec(line)) !== null) {
            const hash = m[1]
            if (map.has(hash) || isProof(hash, entries)) continue
            const c = (counters.get(section) || 0) + 1
            counters.set(section, c)
            map.set(hash, `${section}.${c}`)
        }
    }
    return map
}

/** Build the project-wide numbering from all chapter docs (sorted by filename). */
export function buildProjectNumbering(
    docs: { filename: string; content: string }[],
    entries?: Record<string, { record: string }>,
): Numbering {
    const global: Numbering = new Map()

    // Route 1 — the authentic source label `from.at`, stored on the card. Stable
    // regardless of docs; the right number for a faithful transcription.
    if (entries) {
        for (const [hash, e] of Object.entries(entries)) {
            try {
                const rec = JSON.parse(e.record)
                const at = rec?.from?.at
                if (typeof at === 'string' && at && rec.sort !== 'proof') {
                    global.set(hash, { chapter: parseInt(at, 10) || 0, num: at })
                }
            } catch { /* skip unparseable */ }
        }
    }

    // Route 2 — doc-derived `chapter.section.item` for cards without a `from`.
    const sorted = [...docs].sort((a, b) => a.filename.localeCompare(b.filename))
    for (const { filename, content } of sorted) {
        const chapter = chapterOf(content, filename)
        for (const [hash, secItem] of numberDoc(content, entries)) {
            if (!global.has(hash)) global.set(hash, { chapter, num: `${chapter}.${secItem}` })
        }
    }
    return global
}
